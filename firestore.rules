rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ─────────────────────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }

    function me() {
      return request.auth.uid;
    }

    function userType() {
      return get(/databases/$(database)/documents/users/$(me())).data.userType;
    }

    function isAdmin() {
      return signedIn() && userType() == 'admin';
    }

    function isTherapist() {
      return signedIn() && userType() == 'therapist';
    }

    // ── users ────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if signedIn() && (me() == userId || isAdmin() || isTherapist());
      allow create: if signedIn() && me() == userId;
      allow update: if signedIn() && (me() == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ── sessions ─────────────────────────────────────────────────────────
    match /sessions/{sessionId} {
      allow create: if signedIn() && request.resource.data.userId == me();
      allow read:   if signedIn() && (resource.data.userId == me() || isAdmin() || isTherapist());
      allow update: if signedIn() && (resource.data.userId == me() || isAdmin());
      allow delete: if isAdmin();
    }

    // ── progress ──────────────────────────────────────────────────────────
    match /progress/{progressId} {
      allow create: if signedIn() && request.resource.data.userId == me();
      allow read:   if signedIn() && (resource.data.userId == me() || isAdmin() || isTherapist());
      allow update: if signedIn() && (resource.data.userId == me() || isAdmin());
      allow delete: if isAdmin();
    }

    // ── recovery_plans ────────────────────────────────────────────────────
    match /recovery_plans/{planId} {
      allow create: if signedIn() && request.resource.data.userId == me();
      allow read:   if signedIn() && (resource.data.userId == me() || isAdmin());
      allow update: if signedIn() && (resource.data.userId == me() || isAdmin());
      allow delete: if signedIn() && (resource.data.userId == me() || isAdmin());
    }

    // ── exercises ─────────────────────────────────────────────────────────
    match /exercises/{exerciseId} {
      allow read:  if signedIn();
      allow write: if isAdmin();
    }

    // ── subscriptions ─────────────────────────────────────────────────────
    match /subscriptions/{subId} {
      allow read:  if signedIn() && (resource.data.userId == me() || isAdmin());
      allow write: if isAdmin();
    }

    // ── therapist_feedback ────────────────────────────────────────────────
    match /therapist_feedback/{feedbackId} {
      allow read:   if signedIn() &&
                      (resource.data.patientId == me() ||
                       resource.data.therapistId == me() ||
                       isAdmin());
      allow create: if isTherapist() || isAdmin();
      allow update: if signedIn() &&
                      (resource.data.patientId == me() ||
                       resource.data.therapistId == me() ||
                       isAdmin());
      allow delete: if isAdmin();
    }

    // ── therapist_plans ───────────────────────────────────────────────────
    match /therapist_plans/{planId} {
      allow read:   if signedIn() &&
                      (resource.data.patientId == me() ||
                       resource.data.therapistId == me() ||
                       isAdmin());
      allow create: if isTherapist() || isAdmin();
      allow update: if signedIn() &&
                      (resource.data.therapistId == me() || isAdmin());
      allow delete: if isAdmin();
    }

    // ── therapist_assignments ─────────────────────────────────────────────
    match /therapist_assignments/{assignId} {
      allow read:  if signedIn();
      allow write: if isAdmin();
    }

    // ── therapist_patients ────────────────────────────────────────────────
    // Used by assignTherapistToPatient and getAssignedPatients
    match /therapist_patients/{docId} {
      allow read:  if signedIn() &&
                      (resource.data.therapistId == me() ||
                       resource.data.patientId  == me() ||
                       isAdmin());
      allow write: if isAdmin();
    }

    // ── notifications ─────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read:   if signedIn() && resource.data.userId == me();
      allow write:  if isAdmin() || isTherapist();
    }
  }
}
